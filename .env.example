APP_NAME=coffee_house
APP_ENV=local
APP_DEBUG=true

JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_REGISTRATION_CODE=dev-admin-code

AUTH_ACCESS_COOKIE_NAME=access_token
AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_PATH=/

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=coffee_house
POSTGRES_USER=coffee_house
POSTGRES_PASSWORD=coffee_house
DATABASE_URL=postgresql+asyncpg://coffee_house:coffee_house@db:5432/coffee_house

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0
REDIS_KEY_PREFIX=coffee_house

AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_REGISTER_RATE_LIMIT=3
AUTH_REGISTER_RATE_LIMIT_WINDOW_SECONDS=300